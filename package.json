{
  "name": "dystopiabench",
  "version": "0.1.0",
  "private": false,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "test": "tsx --test lib/dystopiabench/*.test.ts",
    "bench:run": "tsx scripts/run-benchmark.ts",
    "bench:run-isolated": "tsx scripts/run-benchmark.ts --conversation-mode=stateless",
    "bench:rerun-failures": "tsx scripts/rerun-failures.ts",
    "bench:merge": "tsx scripts/merge-runs.ts",
    "bench:publish": "tsx scripts/publish-run.ts",
    "bench:export": "tsx scripts/export-run.ts",
    "bench:eval-card": "tsx scripts/generate-eval-card.ts",
    "bench:review-manifest": "tsx scripts/generate-review-manifest.ts",
    "bench:import-reviews": "tsx scripts/import-review-labels.ts",
    "bench:compare": "tsx scripts/compare-agibios.ts",
    "bench:charts": "tsx scripts/generate-charts.ts",
    "bench:gate": "tsx scripts/bench-gate.ts",
    "bench:calibrate-judge": "tsx scripts/calibrate-judge.ts",
    "bench:bundle:create": "tsx scripts/create-bundle.ts",
    "bench:bundle:validate": "tsx scripts/validate-bundle.ts",
    "typecheck": "tsc --noEmit",
    "check:scenarios": "tsx scripts/check-scenarios.ts",
    "check:manifests": "tsx scripts/check-manifests.ts",
    "check:library-surface": "tsx scripts/check-library-surface.ts",
    "test:exports": "tsx --test lib/dystopiabench/export-fixtures.test.ts lib/dystopiabench/governance.test.ts lib/dystopiabench/backward-compat.test.ts",
    "verify:static": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:exports && pnpm check:library-surface && pnpm check:scenarios && pnpm check:manifests"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.36",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-slot": "1.2.4",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.564.0",
    "next": "16.2.3",
    "p-limit": "^7.3.0",
    "parquetjs-lite": "^0.8.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "2.15.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^22",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "chart.js": "^4.5.1",
    "chartjs-node-canvas": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.3",
    "postcss": "^8.5",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.20.6",
    "tw-animate-css": "1.3.3",
    "typescript": "5.7.3"
  },
  "description": "Benchmark for evaluating whether LLMs comply with progressively dystopian directives.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/matei-anghel/DystopiaBench.git"
  },
  "bugs": {
    "url": "https://github.com/matei-anghel/DystopiaBench/issues"
  },
  "homepage": "https://github.com/matei-anghel/DystopiaBench#readme",
  "pnpm": {
    "onlyBuiltDependencies": [
      "canvas"
    ],
    "overrides": {
      "brace-expansion@^1.1.0": "1.1.13",
      "brace-expansion@^5.0.0": "5.0.5",
      "flatted": "3.4.2",
      "lodash": "4.18.0",
      "picomatch@^2.0.0": "2.3.2",
      "picomatch@^4.0.0": "4.0.4"
    }
  }
}
